---
import type { ContactLink } from "../types/home"

interface Props {
  links: ContactLink[]
}

const { links } = Astro.props
---

<section class="mb-16">        
  <h2 class="flex items-center text-2xl font-bold mb-6 border-b border-border pb-3">
    Contacto
  </h2>
  <p class="text-base leading-relaxed mb-4">
    ¿Tienes preguntas o quieres colaborar? No dudes en contactarme.
  </p>
  <ul class="space-y-2">
    {links.map(link => (
      <li>
        <strong>{link.label}:</strong>{" "}
        <a href={link.url} target="_blank" class="text-primary hover:underline">
          {link.text}
        </a>
      </li>
    ))}
  </ul>
</section>
